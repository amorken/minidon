root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

# Go — tabs, width 4 (gofmt default)
[*.go]
indent_style = tab
indent_size = 4

# TypeScript / JavaScript / JSX / TSX
[*.{ts,tsx,js,jsx}]
indent_style = space
indent_size = 2

# JSON / YAML / TOML
[*.{json,yaml,yml,toml}]
indent_style = space
indent_size = 2

# Markdown — preserve trailing spaces (line breaks)
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# Makefile — tabs required
[Makefile]
indent_style = tab
