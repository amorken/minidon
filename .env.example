# minidon Configuration Example

# TCP address to listen on
MINIDON_LISTEN=:8080

# Mastodon instance URL
MINIDON_MASTODON_INSTANCE=https://mstdn.social

# Mastodon Client ID (optional, leave empty if public timeline stream doesn't require it)
MINIDON_MASTODON_CLIENT_ID=

# Mastodon Client Secret (optional, leave empty if public timeline stream doesn't require it)
MINIDON_MASTODON_CLIENT_SECRET=

# Mastodon Access Token (required, get from Mastodon account settings -> Development -> New Application)
MINIDON_MASTODON_ACCESS_TOKEN=your_access_token_here

# Mastodon streaming API path
MINIDON_MASTODON_STREAM_PATH=api/v1/streaming

# Mastodon stream type: user, public, user:local, or public:local
MINIDON_MASTODON_STREAM=public

# MeiliSearch URL
MINIDON_MEILI_URL=http://localhost:7700

# MeiliSearch Master API key (used to resolve Default Admin API Key)
MINIDON_MEILI_KEY=your_meilisearch_master_key_here

# Ring buffer size: number of recent statuses to hold in memory
MINIDON_BUFFER_SIZE=500

# Disable search functionality completely (set to true to run without MeiliSearch)
MINIDON_DISABLE_SEARCH=false

# Enable verbose debug logging
MINIDON_VERBOSE=false
